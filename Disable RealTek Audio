$device = Get-PnpDevice -Class Media | Where-Object {
    $_.FriendlyName -match "Realtek" -and
    $_.InstanceId -notlike "SWD\*" -and
    $_.InstanceId -notlike "ROOT\*" -and
    $_.InstanceId -like "HDAUDIO*"
} | Select-Object -First 1

if (-not $device) {
    Write-Error "No physical Realtek audio device found."
    Get-PnpDevice -Class Media | Select-Object Status, FriendlyName, InstanceId
    exit 1
}

Write-Host "Disabling: $($device.FriendlyName)"
Write-Host "InstanceId: $($device.InstanceId)"

Disable-PnpDevice -InstanceId $device.InstanceId -Confirm:$false
